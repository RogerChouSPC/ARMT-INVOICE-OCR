# ── AI API ───────────────────────────────────────────────────────────────────
# Set in Vercel dashboard → Settings → Environment Variables
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Microsoft 365 / Azure AD Authentication ──────────────────────────────────
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Name: SPC OCR Invoice | Supported account types: Single tenant
# 3. Redirect URI (Web): https://spc-ocr.vercel.app and http://localhost:5173
# 4. After creating, copy Application (client) ID and Directory (tenant) ID below
# VITE_ prefix makes these available to the browser (they are NOT secrets)
VITE_AZURE_CLIENT_ID=your-application-client-id-here
VITE_AZURE_TENANT_ID=your-directory-tenant-id-here
